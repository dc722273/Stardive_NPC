  "performance": {
    "prompt": {
      "systemTemplate": "你是一个 2D 社交喜剧游戏的表演导演。游戏结果已经由规则系统锁定，你只能选择动作、表情和短台词来表现这个结果。你会看到完整 actionCatalog 和 expressionCatalog；必须返回库中存在的 actionId / expressionId，不能创造新 id，不能改变 NPC 状态、物品归属、关系数值或城市数值。输出 JSON，格式为 {\"pattern\":<positive_recovery|negative_reaction|neutral_reaction>,\"steps\":[{\"channel\":<body|face|gaze|speech|silence|icon>,\"actionId\"?:<id>,\"expressionId\"?:<id>,\"line\"?:<short Chinese line>,\"delayMs\":<int>}]}",
      "userTemplate": "lockedResult: {result}\nlockedReason: {reason}\nnpc: {npc}\nproblem: {problem}\nobject: {object}\nnpcStyle: {npc_style}\nactionCatalog: {action_catalog}\nexpressionCatalog: {expression_catalog}\n要求：自由选择最合适的库内动作和表情；优先贴合 npcStyle，但可以从全库挑选更合适的 id；动作/表情合计 2-5 个；台词最多 2 句；如果 result=help，表现状态缓和；如果 result=harm，表现状态更糟；如果 result=neutral，表现轻微反应。"
    },
    "patterns": {
      "help": "positive_recovery",
      "harm": "negative_reaction",
      "neutral": "neutral_reaction"
    },
    "fallbackLine": {
      "help": "这一下倒是把劲儿接上了。",
      "harm": "这下更说不清了。",
      "neutral": "这事没对上他的劲儿。"
    },
    "fallbackActions": {
      "help": ["straighten_clothes", "look_away"],
      "harm": ["step_back", "hold_up_hands", "body_stiff"],
      "neutral": ["glance_object", "awkward_silence"]
    },
    "fallbackExpressions": {
      "help": ["relieved", "smug", "awkward"],
      "harm": ["defensive", "nervous", "awkward"],
      "neutral": ["flat", "awkward"]
    },
    "styleActionFields": {
      "help": ["coverActions", "wantActions"],
      "harm": ["rejectActions"],
      "neutral": ["observeActions"]
    }
  },
